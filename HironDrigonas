local TabPrincipal = Window:Tab({ Title = "Admin", Icon = "shield" })

local SecaoPlayers = TabPrincipal:Section({ Title = "Jogadores", Opened = true })

local SelectedPlayer = nil
local PlayerDropdown = nil

local function AtualizarListaPlayers()
    local lista = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            table.insert(lista, plr.Name)
        end
    end
    table.sort(lista)
    if PlayerDropdown then
        PlayerDropdown:Refresh(lista, true)
    end
end

PlayerDropdown = SecaoPlayers:Dropdown({
    Title = "Selecione o otário",
    Values = {},
    Multi = false,
    Default = 1,
    Callback = function(valor)
        SelectedPlayer = valor
        print("Alvo selecionado: " .. (valor or "ninguém"))
    end
})

SecaoPlayers:Button({
    Title = "Atualizar lista de players",
    Callback = function()
        AtualizarListaPlayers()
        print("Lista atualizada, seu arrombado!")
    end
})

