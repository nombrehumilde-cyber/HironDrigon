-- Serviços básicos que já estavam no teu script
local Players        = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer    = Players.LocalPlayer

local BoardRemote = nil
local BoardCount  = nil

-- Tenta achar o remote (igual teu script)
pcall(function()
    local re = ReplicatedStorage:FindFirstChild("RE")
    if re then
        BoardRemote = re:FindFirstChild("1Schoo1lDr1yBoard1s")
    end
    -- BoardCount também (se precisar)
    local workspaceCom = workspace:FindFirstChild("WorkspaceCom")
    if workspaceCom then
        -- ... (pode manter a busca completa se quiser, mas aqui simplifiquei)
        BoardCount = workspaceCom:FindFirstChild("Count", true) -- tentativa genérica
    end
end)

local function EnviarComando(cmd, alvo)
    local texto = ";" .. cmd
    if alvo and alvo ~= "" then
        texto = texto .. " " .. alvo:lower()
    end

    if BoardRemote then
        BoardRemote:FireServer("ReturningBoardName", BoardCount, texto)
        print("📤 Enviou pro board → " .. texto)
    else
        -- fallback chat
        local chatEvent = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
        if chatEvent and chatEvent:FindFirstChild("SayMessageRequest") then
            chatEvent.SayMessageRequest:FireServer(texto, "All")
            print("📨 Enviou via chat → " .. texto)
        else
            warn("Nem board nem chat event encontrado. Comando não enviado.")
        end
    end
end

