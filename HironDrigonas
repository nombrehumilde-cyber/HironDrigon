-- Toggles
local jailAtivado = {}
local freezeAtivado = {}
local iceAtivado = {}

SecaoComandos:Toggle({
    Title = "Jail / Soltar",
    Default = false,
    Callback = function(ativado)
        if not SelectedPlayer then
            print("Escolhe alguém primeiro, seu burro do caralho!")
            return
        end

        local nome = SelectedPlayer
        if ativado then
            EnviarComando("jail", nome)
            jailAtivado[nome] = true
            print("Jail ligado em " .. nome)
        else
            EnviarComando("unjail", nome)
            jailAtivado[nome] = nil
            print("Jail desligado em " .. nome)
        end
    end
})

SecaoComandos:Toggle({
    Title = "Freeze / Unfreeze",
    Default = false,
    Callback = function(ativado)
        if not SelectedPlayer then return end

        local nome = SelectedPlayer
        if ativado then
            EnviarComando("freeze", nome)
            freezeAtivado[nome] = true
        else
            EnviarComando("unfreeze", nome)
            freezeAtivado[nome] = nil
        end
    end
})

SecaoComandos:Toggle({
    Title = "Ice / Unice",
    Default = false,
    Callback = function(ativado)
        if not SelectedPlayer then return end

        local nome = SelectedPlayer
        if ativado then
            -- Aqui você pode trocar por outro comando se "ice" não existir no teu sistema
            -- Por enquanto usando "freeze" como base, ou troca por "ice" se tiver
            EnviarComando("freeze", nome)   -- ← altera aqui se tiver comando diferente
            iceAtivado[nome] = true
        else
            EnviarComando("unfreeze", nome)
            iceAtivado[nome] = nil
        end
    end
})

