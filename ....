local ESP2Connections = {}
local ESP2Guis = {}

local function clearESP2()
	for _,gui in pairs(ESP2Guis) do
		if gui then gui:Destroy() end
	end
	ESP2Guis = {}

	for _,c in pairs(ESP2Connections) do
		if c then c:Disconnect() end
	end
	ESP2Connections = {}
end

local function createESP2(player, color)
	if player == LocalPlayer then return end

	local function apply(char)
		local head = char:WaitForChild("Head", 5)
		if not head then return end

		if ESP2Guis[player] then
			ESP2Guis[player]:Destroy()
		end

		local bill = Instance.new("BillboardGui")
		bill.Name = "ESP2"
		bill.AlwaysOnTop = true
		bill.Size = UDim2.new(0,200,0,50)
		bill.StudsOffset = Vector3.new(0,2.5,0)
		bill.Parent = head

		local txt = Instance.new("TextLabel")
		txt.Size = UDim2.new(1,0,1,0)
		txt.BackgroundTransparency = 1
		txt.Text = player.Name
		txt.TextColor3 = color
		txt.TextStrokeTransparency = 0
		txt.TextStrokeColor3 = Color3.new(0,0,0)
		txt.Font = Enum.Font.SourceSansBold
		txt.TextScaled = true
		txt.Parent = bill

		ESP2Guis[player] = bill
	end

	if player.Character then
		apply(player.Character)
	end

	ESP2Connections[player] = player.CharacterAdded:Connect(apply)
end

Commands["esp2"] = function(colorName)
	clearESP2()

	local colors = {
		vermelho = Color3.fromRGB(255,0,0),
		azul = Color3.fromRGB(0,0,255),
		verde = Color3.fromRGB(0,255,0),
		amarelo = Color3.fromRGB(255,255,0),
		roxo = Color3.fromRGB(128,0,128),
		branco = Color3.fromRGB(255,255,255)
	}

	local color = colors[colorName and colorName:lower()] or Color3.fromRGB(255,255,255)

	for _,plr in pairs(Players:GetPlayers()) do
		createESP2(plr, color)
