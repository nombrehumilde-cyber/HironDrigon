local ESPs = {}

Commands["esp"] = function(colorName)
	local colors = {
		vermelho = Color3.fromRGB(255,0,0),
		azul = Color3.fromRGB(0,0,255),
		verde = Color3.fromRGB(0,255,0),
		amarelo = Color3.fromRGB(255,255,0),
		roxo = Color3.fromRGB(128,0,128),
		branco = Color3.fromRGB(255,255,255)
	}

	local espColor = colors[colorName:lower()] or Color3.fromRGB(255,255,255)

	-- Limpa ESP antigo
	for _,esp in pairs(ESPs) do
		if esp and esp.Parent then
			esp:Destroy()
		end
	end
	ESPs = {}

	-- Cria ESP para cada player
	for _,plr in pairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
			local box = Instance.new("BoxHandleAdornment")
			box.Adornee = plr.Character:FindFirstChild("HumanoidRootPart")
			box.Size = Vector3.new(2,3,1)
			box.Color3 = espColor
			box.Transparency = 0.5
			box.AlwaysOnTop = true
			box.ZIndex = 10
			box.Parent = plr.Character:FindFirstChild("HumanoidRootPart")
			table.insert(ESPs, box)
		end
	end

	Notify("ESP", "ESP ativado com cor "..colorName)
end

