local PurpleSquares = {}
local SquareCount = 35

local MenuWidth = MenuFrame.Size.X.Offset
local MenuHeight = MenuFrame.Size.Y.Offset

for i = 1, SquareCount do
	local size = math.random(4, 10)

	local sq = Instance.new("Frame")
	sq.Size = UDim2.new(0, size, 0, size)
	sq.Position = UDim2.new(
		0, math.random(0, MenuWidth - size),
		0, math.random(30, MenuHeight - size)
	)
	sq.BackgroundColor3 = Color3.fromRGB(170, 0, 255) -- ROXO
	sq.BackgroundTransparency = math.random(0, 30) / 100
	sq.BorderSizePixel = 0
	sq.Parent = MenuFrame

	table.insert(PurpleSquares, {
		frame = sq,
		speed = math.random(1, 3),
		phase = math.random() * 10
	})
end

RunService.RenderStepped:Connect(function()
	for _,data in ipairs(PurpleSquares) do
		local sq = data.frame

		-- movimento vertical
		sq.Position = UDim2.new(
			0, sq.Position.X.Offset,
			0, sq.Position.Y.Offset + data.speed
		)

		-- reset quando sai da tela
		if sq.Position.Y.Offset > MenuHeight then
			sq.Position = UDim2.new(
				0, math.random(0, MenuWidth - sq.Size.X.Offset),
				0, 30
			)
		end

		-- efeito de pulsar
		data.phase += 0.15
		local pulse = (math.sin(data.phase) + 1) / 2
		sq.BackgroundColor3 = Color3.fromRGB(
			150 + pulse * 80,
			0,
			200 + pulse * 55
		)
	end
end)-- ===============================================
