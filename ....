local ClickFlingTool = nil
local ClickFlingSpin = nil
local Flinging = false

local MAX_DISTANCE = 25

local function cleanup(hum)
	Flinging = false
	Noclip = false

	if ClickFlingSpin then
		ClickFlingSpin:Destroy()
		ClickFlingSpin = nil
	end

	if hum then
		Camera.CameraSubject = hum
	end
end

Commands["clickfling"] = function()
	-- destrói tool antiga se existir
	if ClickFlingTool then
		ClickFlingTool:Destroy()
		ClickFlingTool = nil
	end

	local char = LocalPlayer.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hum or not hrp then return end

	-- cria tool NOVA sempre
	ClickFlingTool = Instance.new("Tool")
	ClickFlingTool.Name = "fling"
	ClickFlingTool.RequiresHandle = false
	ClickFlingTool.CanBeDropped = true
	ClickFlingTool.Parent = LocalPlayer.Backpack

	-- clique = FLING
	ClickFlingTool.Activated:Connect(function()
		if Flinging then return end

		local mouse = LocalPlayer:GetMouse()
		if not mouse.Target then return end

		local model = mouse.Target:FindFirstAncestorOfClass("Model")
		if not model or model == char then return end

		local targetHRP = model:FindFirstChild("HumanoidRootPart")
		local targetHum = model:FindFirstChildOfClass("Humanoid")
		if not targetHRP or not targetHum then return end

		Flinging = true
		Noclip = true

		-- spin
		ClickFlingSpin = Instance.new("BodyAngularVelocity")
		ClickFlingSpin.Name = "ClickFlingSpin"
		ClickFlingSpin.AngularVelocity = Vector3.new(0,99999,0)
		ClickFlingSpin.MaxTorque = Vector3.new(0,math.huge,0)
		ClickFlingSpin.Parent = hrp

		-- view
		Camera.CameraSubject = targetHum

		-- loop enquanto no chão e perto
		task.spawn(function()
			while Flinging do
				if hum.FloorMaterial == Enum.Material.Air then break end
				if not targetHRP.Parent then break end
				if (hrp.Position - targetHRP.Position).Magnitude > MAX_DISTANCE then break end

				hrp.CFrame = targetHRP.CFrame
				task.wait(0.1)
			end

			cleanup(hum)
		end)
	end)

	-- sentou = cancela
	hum.Seated:Connect(function(active)
		if active then
			cleanup(hum)
			if ClickFlingTool then
				ClickFlingTool.Parent = Workspace
				ClickFlingTool = nil
			end
		end
	end)

	Notify("ClickFling", "Tool criada. Pode morrer e executar de novo.")
end 
