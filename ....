-- guarda o ExecuteCommand original
local _OldExecuteCommand = ExecuteCommand

-- sobrescreve
function ExecuteCommand(text)
	local args = text:split(" ")
	local cmd = args[1]:lower()

	local success = false
	local ok, err = pcall(function()
		_OldExecuteCommand(text)
	end)

	-- validações simples (sem frescura)
	if cmd == ";speed" then
		success = (args[2] == "me" and tonumber(args[3]) ~= nil)

	elseif cmd == ";jumppower" then
		success = tonumber(args[2]) ~= nil

	elseif cmd == ";gravity" then
		success = tonumber(args[2]) ~= nil

	elseif Commands[cmd:sub(2)] then
		success = true
	end

	if success then
		ShowCmdNotify(text:sub(2) .. " ativado", true)
	else
		ShowCmdNotify("comando errado", false)
	end
end-- === COMANDO ;console ===
