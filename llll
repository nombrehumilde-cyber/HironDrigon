--==================================================
-- PEGAR LISTA DE JOGADORES (atualizada)
--==================================================
local function GetPlayers()
    local list = {}
    for _, player in Players:GetPlayers() do
        if player ~= LocalPlayer and player.Character then
            table.insert(list, player.Name)
        end
    end
    return list
end

--==================================================
-- FUNÇÕES QUE REALMENTE FAZEM ALGO
--==================================================
local function GetCharacter(playerName)
    local plr = Players:FindFirstChild(playerName)
    if plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        return plr.Character
    end
    return nil
end

local function Kill(targetName)
    local char = GetCharacter(targetName)
    if not char then warn("["..targetName.."] sem character, fudeu") return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.Health = 0
        print("Morreu na porrada: " .. targetName)
    end
end

local function Freeze(targetName)
    local char = GetCharacter(targetName)
    if not char then warn("Sem character pra congelar") return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
        
        -- pra ficar mais "congelado" ainda (opcional)
        for _, part in char:GetChildren() do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Anchored = true
            end
        end
        
        print("Congelou o arrombado: " .. targetName)
    end
end

local function Unfreeze(targetName)
    local char = GetCharacter(targetName)
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = 16
        humanoid.JumpPower = 50
        
        for _, part in char:GetChildren() do
            if part:IsA("BasePart") then
                part.Anchored = false
            end
        end
        
        print("Descongelou: " .. targetName)
    end
end

local function Jail(targetName)
    local char = GetCharacter(targetName)
    if not char then warn("Sem character pra prender") return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Cria uma "prisão" simples (pode melhorar depois)
    local jail = Instance.new("Part")
    jail.Name = "JailCage"
    jail.Size = Vector3.new(10, 20, 10)
    jail.Position = root.Position + Vector3.new(0, 10, 0)
    jail.Anchored = true
    jail.CanCollide = true
    jail.Transparency = 0.4
    jail.BrickColor = BrickColor.new("Really red")
    jail.Parent = workspace
    
    root.Anchored = true  -- prende o cara
    print("Prendeu o viado: " .. targetName .. " (prisão básica)")
end

local function Unjail(targetName)
    local char = GetCharacter(targetName)
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        root.Anchored = false
    end
    
    -- remove prisão se existir
    for _, obj in workspace:GetChildren() do
        if obj.Name == "JailCage" then
            obj:Destroy()
        end
    end
    
    print("Soltou o cuzão: " .. targetName)
end

