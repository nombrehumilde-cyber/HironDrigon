local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

WindUI:SetTheme("Dark")

local Window = WindUI:CreateWindow({
    Title = "Spectra Admin",
    Icon = "rbxassetid://7733964640",
    Author = "Spectra",
    Folder = "SpectraAdmin",
    Size = UDim2.fromOffset(500,350),
    Transparent = true
})

local SelectedPlayer

local function GetPlayers()

    local list = {}

    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            table.insert(list,p.Name)
        end
    end

    return list

end

local Tab = Window:Tab({
    Title = "Admin",
    Icon = "shield"
})

local Section = Tab:Section({
    Title = "Player Commands"
})

Section:Dropdown({
    Title = "Selecionar Jogador",
    Values = GetPlayers(),
    Callback = function(v)
        SelectedPlayer = v
    end
})

local function Send(cmd)

    if not SelectedPlayer then return end

    SpectraRemote:FireServer(cmd,SelectedPlayer)

end

Section:Button({
    Title = "Kill",
    Callback = function()
        Send("kill")
    end
})

Section:Button({
    Title = "Jail",
    Callback = function()
        Send("jail")
    end
})

Section:Button({
    Title = "Unjail",
    Callback = function()
        Send("unjail")
    end
})

Section:Button({
    Title = "Freeze",
    Callback = function()
        Send("freeze")
    end
})

Section:Button({
    Title = "Unfreeze",
    Callback = function()
        Send("unfreeze")
    end
})