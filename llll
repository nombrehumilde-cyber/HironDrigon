--// SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer

--====================================
-- REMOTE DO SPECTRA
--====================================

local SpectraRemote = ReplicatedStorage:FindFirstChild("SpectraRemote")

if not SpectraRemote then
    SpectraRemote = Instance.new("RemoteEvent")
    SpectraRemote.Name = "SpectraRemote"
    SpectraRemote.Parent = ReplicatedStorage
end

--====================================
-- SISTEMA DE COMANDOS
--====================================

local FrozenPlayers = {}
local JailedPlayers = {}

local function Kill()
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Health = 0
    end
end

local function Freeze()
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        FrozenPlayers[LocalPlayer.Name] = hum.WalkSpeed
        hum.WalkSpeed = 0
    end
end

local function Unfreeze()
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = FrozenPlayers[LocalPlayer.Name] or 16
    end
end

local function Jail()
    if not LocalPlayer.Character then return end
    
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local cage = Instance.new("Part")
    cage.Size = Vector3.new(8,8,8)
    cage.Anchored = true
    cage.Transparency = 0.5
    cage.Material = Enum.Material.ForceField
    cage.Position = hrp.Position
    cage.Parent = workspace
    
    JailedPlayers[LocalPlayer.Name] = cage
end

local function Unjail()
    local cage = JailedPlayers[LocalPlayer.Name]
    
    if cage then
        cage:Destroy()
        JailedPlayers[LocalPlayer.Name] = nil
    end
end

--====================================
-- RECEBER COMANDOS
--====================================

SpectraRemote.OnClientEvent:Connect(function(cmd,target)

    if target ~= LocalPlayer.Name then
        return
    end
    
    if cmd == "kill" then
        Kill()
        
    elseif cmd == "freeze" then
        Freeze()
        
    elseif cmd == "unfreeze" then
        Unfreeze()
        
    elseif cmd == "jail" then
        Jail()
        
    elseif cmd == "unjail" then
        Unjail()
        
    end
    
end)

